datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "./.prisma/client"
}

model Event {
  id                 Int            @id @default(autoincrement()) @map("id")
  secret_key         String?        @default(uuid())              @map("secret_key")
  event_title        String?                                      @map("event_title")
  event_description  String?                                      @map("event_description")
  credits_per_voter  Int            @default(5)                   @map("credits_per_voter")
  start_event_date   DateTime       @default(now())               @map("start_event_date")
  end_event_date     DateTime       @default(now())               @map("end_event_date")
  created_at         DateTime       @default(now())               @map("created_at")
  event_data         Json?                                        @map("event_data")

  items              EventItem[]
  voters_relations   VoterOnEvent[]
  voters             Voter[]

  @@map("events")
}

model Voter {
  id          Int               @id @default(autoincrement()) @map("id")
  voter_name  String?                                         @map("voter_name")

  events           Event[]
  events_relations VoterOnEvent[]
  votes            Vote[]

  @@map("voters")
}

model VoterOnEvent {
  id         Int     @id @default(autoincrement()) @map("id")
  event_id   Int                                   @map("event_id")
  voter_id   Int                                   @map("voter_id")

  event      Event   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  voter      Voter   @relation(fields: [voter_id], references: [id], onDelete: Cascade)

  @@map("voter_on_event")
}

model Vote {
  id              Int         @id @default(autoincrement()) @map("id")
  event_item_id   Int                                       @map("event_item_id")
  voter_id        Int                                       @map("voter_id")
  points          Int                                       @map("points")

  event_item      EventItem   @relation(fields: [event_item_id], references: [id], onDelete: Cascade)
  voter           Voter       @relation(fields: [voter_id], references: [id], onDelete: Cascade)

  @@map("votes")
  @@unique([event_item_id, voter_id])
}

model EventItem {
  id                Int       @id @default(autoincrement()) @map("id")
  event_id          Int                                     @map("event_id")
  name              String                                  @map("name")
  url               String?                                 @map("url")
  description       String?                                 @map("description")
  created_at        DateTime  @default(now())               @map("created_at")
  added_by_user_id  Int                                     @map("added_by_user_id")

  event             Event     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  votes             Vote[]

  @@map("event_items")
}
